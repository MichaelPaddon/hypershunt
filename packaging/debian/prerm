#!/bin/sh
set -e

case "$1" in
    remove|deconfigure)
        if [ -d /run/systemd/system ]; then
            systemctl --system stop    hypershunt.service >/dev/null 2>&1 || true
            systemctl --system disable hypershunt.service >/dev/null 2>&1 || true
        fi
        ;;
esac

#DEBHELPER#
